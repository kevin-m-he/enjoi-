# Keep the build context small and the image clean of licensed/heavy artifacts.
**/__pycache__/
**/*.pyc
.git/
*.log

# Python envs / scratch
backend/.venv/
backend/venv/
backend/.wheels/

# LICENSED loops — never bake these into an image (served from the R2 CDN at
# runtime). The committed sample_manifest.json (metadata only) is NOT ignored.
backend/sample_library/

# Frontend build artifacts (the SPA deploys separately to Cloudflare Pages)
frontend/node_modules/
frontend/dist/
frontend/dist-electron/
frontend/release/
