# Copy to ".env" on the server (same folder as docker-compose.yml) and fill in.
# These point the backend at your PRIVATE sample CDN (the token-gated R2 Worker).
# The token stays server-side only — it is never sent to the browser.
ENJOI_SAMPLE_CDN=https://enjoi-samples.<your-subdomain>.workers.dev
ENJOI_SAMPLE_CDN_TOKEN=<the SAMPLE_TOKEN you set with `wrangler secret put`>
