{
  // Serves the enjoi web frontend (the Vite/React SPA) as a static-assets Worker.
  // Cloudflare's "Workers" Git flow uses this: it runs the build command, then
  // `npx wrangler deploy` uploads ./frontend/dist as static files. (The separate
  // sample-library Worker lives in cloudflare/sample-worker/ with its own config.)
  "name": "enjoi",
  "compatibility_date": "2024-11-01",
  "assets": {
    "directory": "./frontend/dist",
    "not_found_handling": "single-page-application"
  }
}
